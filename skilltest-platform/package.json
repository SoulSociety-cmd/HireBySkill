{
  "name": "skilltest-platform",
  "version": "1.0.0",
  "description": "SkillTest Platform - Connect companies with students through real skill tests",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "cd client && npx vite",
    "build": "cd client && npx vite build",
    "preview": "cd client && npx vite preview",
    "install-all": "npm install && cd client && npm install",
    "sandbox": "docker-compose -f docker-compose-sandbox.yml up -d"
  },
  "keywords": [
    "skilltest",
    "assessment",
    "coding-test",
    "hiring"
  ],
  "author": "Senior Fullstack Developer",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "dockerode": "^4.0.2",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.4.0",
    "glob": "^11.0.2",
    "google-auth-library": "^9.14.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.23.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "openai": "^5.23.2",
    "socket.io": "^4.8.3",
    "tree-kill": "^1.2.2",
    "vm2": "^3.9.19"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}